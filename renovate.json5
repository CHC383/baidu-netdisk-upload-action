{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:recommended",
    ":maintainLockFilesMonthly",
    ":semanticCommitTypeAll(build)",
    ":dependencyDashboard",
    "workarounds:typesNodeVersioning",
    "customManagers:biomeVersions",
  ],
  rangeStrategy: "bump",
  postUpdateOptions: ["pnpmDedupe"],
  prHourlyLimit: 0,
  packageRules: [
    {
      description: "Enable auto merge for minor, patch and lock file maintenance updates",
      matchUpdateTypes: ["minor", "patch", "lockFileMaintenance"],
      automerge: true,
      platformAutomerge: true,
    },
    {
      description: "Don't bump engines field in package.json",
      matchManagers: ["npm"],
      matchDepTypes: ["engines"],
      rangeStrategy: "auto",
    },
    {
      description: "Align with pnpm's default minimum release age",
      matchDatasources: ["npm"],
      minimumReleaseAge: "1 day",
    },
  ],
  customManagers: [
    {
      customType: "regex",
      description: "Update BaiduPCS-Go version in src/main.ts",
      managerFilePatterns: ["/^src/main\\.ts$/"],
      matchStrings: [
        'renovate: datasource=(?<datasource>[a-z-]+) depName=(?<depName>\\S+)\\s+const BAIDU_PCS_GO_VERSION = "(?<currentValue>[^"]+)";',
      ],
    },
  ],
}
